{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://lolsensei.com/schemas/community/role-change-request.schema.json",
  "x-endpoint": "POST /api/community/mod/users/{id}/role",
  "properties": {
    "user_id": {
      "format": "uuid",
      "title": "User Id",
      "type": "string"
    },
    "new_role": {
      "enum": [
        "user",
        "moderator",
        "admin"
      ],
      "title": "New Role",
      "type": "string"
    },
    "reason": {
      "maxLength": 500,
      "minLength": 5,
      "title": "Reason",
      "type": "string"
    }
  },
  "required": [
    "user_id",
    "new_role",
    "reason"
  ],
  "title": "RoleChangeRequest",
  "type": "object"
}
