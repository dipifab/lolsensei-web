{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://lolsensei.com/schemas/community/thread-list-response.schema.json",
  "x-endpoint": "GET /api/community/threads (list envelope)",
  "$defs": {
    "AuthorSummary": {
      "description": "Rappresentazione minima di un autore nelle response content.\n\nCampi copiati da ``CommunityUser`` + ``has_premium_badge`` derivato\nservice-side (lookup ``user.subscription``). Se l'utente e' stato\nanonymized (``deleted_at`` set), il service popola ``deleted=True``\ne azzerra nickname/avatar.",
      "properties": {
        "id": {
          "format": "uuid",
          "title": "Id",
          "type": "string"
        },
        "nickname": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Nickname"
        },
        "avatar_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Avatar Url"
        },
        "role": {
          "enum": [
            "user",
            "moderator",
            "admin"
          ],
          "title": "Role",
          "type": "string"
        },
        "has_premium_badge": {
          "default": false,
          "title": "Has Premium Badge",
          "type": "boolean"
        },
        "deleted": {
          "default": false,
          "title": "Deleted",
          "type": "boolean"
        }
      },
      "required": [
        "id",
        "role"
      ],
      "title": "AuthorSummary",
      "type": "object"
    },
    "CategorySummary": {
      "description": "Sub-object delle response thread (non espone i18n full, solo la\n``name`` gia risolta per la request lang).",
      "properties": {
        "id": {
          "format": "uuid",
          "title": "Id",
          "type": "string"
        },
        "slug": {
          "title": "Slug",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "order_index": {
          "default": 100,
          "title": "Order Index",
          "type": "integer"
        },
        "is_admin_only": {
          "default": false,
          "title": "Is Admin Only",
          "type": "boolean"
        },
        "is_premium_only": {
          "default": false,
          "title": "Is Premium Only",
          "type": "boolean"
        }
      },
      "required": [
        "id",
        "slug",
        "name"
      ],
      "title": "CategorySummary",
      "type": "object"
    },
    "TagResponse": {
      "description": "Response per endpoint ``GET /api/community/tags`` (api-contracts \u00a73.13).",
      "properties": {
        "id": {
          "format": "uuid",
          "title": "Id",
          "type": "string"
        },
        "slug": {
          "title": "Slug",
          "type": "string"
        },
        "usage_count": {
          "title": "Usage Count",
          "type": "integer"
        }
      },
      "required": [
        "id",
        "slug",
        "usage_count"
      ],
      "title": "TagResponse",
      "type": "object"
    },
    "ThreadSummary": {
      "description": "Item lista thread (``ThreadListItem`` api-contracts \u00a73.2).",
      "properties": {
        "id": {
          "format": "uuid",
          "title": "Id",
          "type": "string"
        },
        "slug": {
          "title": "Slug",
          "type": "string"
        },
        "title": {
          "title": "Title",
          "type": "string"
        },
        "category": {
          "$ref": "#/$defs/CategorySummary"
        },
        "author": {
          "anyOf": [
            {
              "$ref": "#/$defs/AuthorSummary"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "tags": {
          "items": {
            "$ref": "#/$defs/TagResponse"
          },
          "title": "Tags",
          "type": "array"
        },
        "reply_count": {
          "default": 0,
          "title": "Reply Count",
          "type": "integer"
        },
        "reaction_count": {
          "default": 0,
          "title": "Reaction Count",
          "type": "integer"
        },
        "language": {
          "default": "en",
          "title": "Language",
          "type": "string"
        },
        "status": {
          "default": "published",
          "enum": [
            "published",
            "pending_review",
            "rejected",
            "hidden_by_staff"
          ],
          "title": "Status",
          "type": "string"
        },
        "has_staff_response": {
          "default": false,
          "title": "Has Staff Response",
          "type": "boolean"
        },
        "excerpt": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Excerpt"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "edited_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Edited At"
        }
      },
      "required": [
        "id",
        "slug",
        "title",
        "category",
        "created_at"
      ],
      "title": "ThreadSummary",
      "type": "object"
    }
  },
  "description": "Response paginata ``GET /api/v1/public/community/threads``.",
  "properties": {
    "items": {
      "items": {
        "$ref": "#/$defs/ThreadSummary"
      },
      "title": "Items",
      "type": "array"
    },
    "page": {
      "title": "Page",
      "type": "integer"
    },
    "page_size": {
      "title": "Page Size",
      "type": "integer"
    },
    "total": {
      "title": "Total",
      "type": "integer"
    },
    "has_more": {
      "title": "Has More",
      "type": "boolean"
    }
  },
  "required": [
    "items",
    "page",
    "page_size",
    "total",
    "has_more"
  ],
  "title": "ThreadListResponse",
  "type": "object"
}
