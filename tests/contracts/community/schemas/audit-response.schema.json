{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://lolsensei.com/schemas/community/audit-response.schema.json",
  "x-endpoint": "GET /api/community/mod/audit",
  "$defs": {
    "AuditLogItem": {
