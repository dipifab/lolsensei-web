# CSP note: la direttiva Content-Security-Policy e emessa dal Worker middleware
# (`src/middleware.ts` + `src/generated/csp-hashes.ts`). Cloudflare Pages/Workers
# rifiuta linee > 2000 char in _headers, e con 79 hash SHA-256 inline script la
# direttiva superava i 4700 char → deploy fail [code: 10021]. Vedi TASK-W18-T31.
# Gli altri security header (HSTS, nosniff, frame-ancestors proxy via XFO, etc.)
# restano qui come backstop statico.

/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  X-XSS-Protection: 0
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=(), browsing-topics=(), payment=(self), fullscreen=(self)
  Cross-Origin-Resource-Policy: same-origin
  Report-To: {"group":"csp-endpoint","max_age":10886400,"endpoints":[{"url":"/csp-report"}]}

/*.html
  Cache-Control: public, max-age=300, stale-while-revalidate=60

/_build/assets/*
  Cache-Control: public, max-age=31536000, immutable

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/images/*
  Cache-Control: public, max-age=2592000

# Admin console + checkout - never index (baseline WP10, reinforced by WP21 ConsoleGate)
/*/checkout/*
  X-Robots-Tag: noindex, nofollow
  Cache-Control: no-store

/console
  X-Robots-Tag: noindex, nofollow
  Cache-Control: no-store

/console/*
  X-Robots-Tag: noindex, nofollow
  Cache-Control: no-store

/console-login
  X-Robots-Tag: noindex, nofollow
  Cache-Control: no-store

/auth/*
  X-Robots-Tag: noindex, nofollow

# WP31 F4-13 — Premium private content (REQ-NF-031-007).
# Match-history dashboard + per-match review pages contain user-specific
# data (champion/KDA/AI summary tied to the signed-in account). They MUST
# never be indexed by search engines. Defense-in-depth with the
# `<NoindexMeta>` <meta> tag emitted by the route handlers — the
# X-Robots-Tag at the edge wins even if the meta is stripped by a proxy.
/*/match-history
  X-Robots-Tag: noindex, nofollow
  Cache-Control: no-store

/*/match-history/*
  X-Robots-Tag: noindex, nofollow
  Cache-Control: no-store

/*/match/*
  X-Robots-Tag: noindex, nofollow
  Cache-Control: no-store

# WP32 F5-14 — Coach add-on private content (REQ-NF-032-004).
# /coach (dashboard) + /coach/addon (activation) hold user-specific add-on
# state, AI conversation history (in-memory) and addon lifecycle controls.
# noindex defense-in-depth with the route-level <NoindexMeta>.
/*/coach
  X-Robots-Tag: noindex, nofollow
  Cache-Control: no-store

/*/coach/*
  X-Robots-Tag: noindex, nofollow
  Cache-Control: no-store

/favicon.ico
  Cache-Control: public, max-age=86400

/sitemap.xml
  Cache-Control: public, max-age=3600

/robots.txt
  Cache-Control: public, max-age=3600

/llms.txt
  Cache-Control: public, max-age=3600

/riot.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=300
  X-Content-Type-Options: nosniff
