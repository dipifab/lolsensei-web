{
  "ci": {
    "collect": {
      "url": [
        "http://127.0.0.1:8787/en/",
        "http://127.0.0.1:8787/en/pricing",
        "http://127.0.0.1:8787/en/faq",
        "http://127.0.0.1:8787/en/blog",
        "http://127.0.0.1:8787/en/privacy",
        "http://127.0.0.1:8787/en/cookies"
      ],
      "numberOfRuns": 3,
      "settings": {
        "_comment": "WP19.1 TASK-3-005: default CLI preset Lighthouse 13.x = mobile Moto G Power + Slow 4G. Desktop qui mantenuto per profili non-gate. Gate mobile eseguito via npx lighthouse manuale (NON lhci), vedi mobile_target.",
        "preset": "desktop"
      }
    },
    "mobile_target": {
      "_comment": "WP19.1 gate REQ-NF-019-1-005. Invocazione manuale via npx lighthouse (NON lhci autorun), vedi dev-repository/design/wp19_1/api-contracts.md §4. Soglia LCP <2000ms, delta ≥500ms vs baseline 4290ms.",
      "url": "https://www.lolsensei.com/en/",
      "numberOfRuns": 3,
      "variance_threshold_ms": 1000,
      "variance_threshold_pct": 30,
      "assertions": {
        "largest-contentful-paint_ms": 2000,
        "cumulative-layout-shift": 0,
        "categories:performance": 0.95
      }
    },
    "assert": {
      "assertMatrix": [
        {
          "matchingUrlPattern": "/en/$",
          "assertions": {
            "first-contentful-paint": ["warn", {"maxNumericValue": 1200}],
            "largest-contentful-paint": ["error", {"maxNumericValue": 2500}],
            "cumulative-layout-shift": ["error", {"maxNumericValue": 0.1}],
            "categories:performance": ["error", {"minScore": 0.9}],
            "categories:accessibility": ["error", {"minScore": 0.95}]
          }
        },
        {
          "matchingUrlPattern": "/en/(privacy|cookies)$",
          "assertions": {
            "first-contentful-paint": ["warn", {"maxNumericValue": 1200}],
            "largest-contentful-paint": ["warn", {"maxNumericValue": 2500}],
            "cumulative-layout-shift": ["warn", {"maxNumericValue": 0.1}],
            "categories:accessibility": ["error", {"minScore": 0.95}]
          }
        },
        {
          "matchingUrlPattern": "/en/.+",
          "assertions": {
            "first-contentful-paint": ["warn", {"maxNumericValue": 1200}],
            "largest-contentful-paint": ["warn", {"maxNumericValue": 2500}],
            "cumulative-layout-shift": ["warn", {"maxNumericValue": 0.1}]
          }
        }
      ]
    }
  }
}
