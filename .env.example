# lolsensei-web — example environment file
# Copiare in `.env.local` (gitignored) per sviluppo locale.
# In produzione i valori sono gestiti via wrangler.toml [vars] + Cloudflare secrets.

# --- Public API ---
VITE_API_BASE_URL=https://api.lolsensei.com
# Optional explicit override for WP32 coach + WP31 match-api services
# (precedence: runtime globalThis.__BACKEND_API_URL__ > VITE_BACKEND_API_URL >
# VITE_API_BASE_URL > production fallback). Leave empty to keep the chain.
VITE_BACKEND_API_URL=

# --- Google OAuth (admin console) ---
VITE_GOOGLE_CLIENT_ID=

# --- Feature flags ---
VITE_PUBLIC_PAGES_ENABLED=true
VITE_CONSENT_BANNER_ENABLED=false

# --- Build metadata ---
VITE_BUILD_VERSION=dev

# --- WP24 GDPR & Cookie Compliance ---
# Versione privacy policy esposta al client (build-time). Deve combaciare con
# il campo `privacy_policy_version` del backend (app/config.py). Bump MAJOR
# (1.x.x -> 2.x.x) forza re-consent a tutti gli utenti (banner riappare).
VITE_PRIVACY_POLICY_VERSION=1.0.0

# Token pubblico Cloudflare Web Analytics. Public by design (CF docs).
# Caricato via <script defer src=".../beacon.min.js" data-cf-beacon='{"token":...}'>.
# Lasciare vuoto in dev per non caricare lo script (graceful degrade).
VITE_CF_ANALYTICS_TOKEN=

# Subresource Integrity hash per beacon.min.js CF (pinned).
# Formato: "sha384-<base64hash>". Rotazione gestita via runbook SRI.
VITE_CF_BEACON_SRI=

# --- WP-COMMUNITY (CR-037) ---
# Variabili esposte al bundle Vite (public by design). Non inserire secret qui.
VITE_TURNSTILE_SITE_KEY=0x4AAAAAAA-site-key
VITE_R2_PUBLIC_BASE_URL=https://avatars.lolsensei.com
VITE_COMMUNITY_API_BASE=https://api.lolsensei.com/api/community
