    "preview": "vite preview",
    "check:bundle-clean": "bash scripts/check-bundle-clean.sh"
  },
  "dependencies": {
    "@solidjs/router": "^0.16.1",
    "@tailwindcss/typography": "^0.5.19",
    "solid-js": "^1.9.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.2",
    "playwright": "^1.59.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vite-plugin-solid": "^2.11.12"
  }
}
