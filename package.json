{
  "name": "lolsensei-web",
  "private": true,
  "version": "1.0.0-wp21",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "bash scripts/check-competitors.sh",
    "build": "tsc -b && vite build",
    "build:beta": "tsc -b && vite build --mode beta",
